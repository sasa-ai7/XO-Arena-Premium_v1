rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isMe(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return signedIn()
        && request.auth.token.email != null
        && request.auth.token.email == 'adminarena77@gmail.com';
    }

    // ── /users/{uid} ──────────────────────────────────────────────────────────
    // Owner can read and write their own user document and all subcollections.
    // Admin can read/write all users.

    match /users/{uid} {
      allow read, create, update, delete: if isMe(uid) || isAdmin();

      match /{subPath=**} {
        allow read, create, update, delete: if isMe(uid) || isAdmin();
      }
    }

    // ── /iap_transactions/{purchaseTokenHash} ─────────────────────────────────
    // Written only by trusted server/Cloud Function.
    // Users may read their own IAP record.

    match /iap_transactions/{purchaseTokenHash} {
      allow read: if isAdmin()
        || (signedIn() && resource.data.uid == request.auth.uid);
      allow create, update, delete: if isAdmin();
    }

    // ── /match_rewards/{rewardId} ─────────────────────────────────────────────
    match /match_rewards/{rewardId} {
      allow read, write: if isAdmin();
    }

    // ── /audit_logs/{logId} ───────────────────────────────────────────────────
    // Client can create best-effort audit log entries.
    match /audit_logs/{logId} {
      allow create: if signedIn();
      allow read, update, delete: if isAdmin();
    }

    match /user_logs/{logId} {
      allow create: if signedIn();
      allow read, update, delete: if isAdmin();
    }

    // ── /deletion_feedback/{uid} ──────────────────────────────────────────────
    // Owner writes their own record (uid field must match). Email check is
    // skipped because some providers may have a different or empty token email.
    match /deletion_feedback/{uid} {
      allow create, update: if isMe(uid)
        && request.resource.data.uid == request.auth.uid;
      allow read, delete: if isAdmin();
    }

    // ── /deletion_requests/{uid} ──────────────────────────────────────────────
    match /deletion_requests/{uid} {
      allow create: if isMe(uid);
      allow read, update, delete: if isAdmin();
    }

    // ── /deleted_accounts/{logId} ─────────────────────────────────────────────
    match /deleted_accounts/{logId} {
      allow create: if signedIn();
      allow read, update, delete: if isAdmin();
    }

    // ── Public catalog collections — read by all, write by admin ─────────────

    match /avatars/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /x_skins/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /o_skins/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /store_items/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── /leaderboard/{document} ───────────────────────────────────────────────
    match /leaderboard/{document=**} {
      allow read: if true;
      allow create, update: if signedIn();
      allow delete: if isAdmin();
    }

    // ── Catch-all: admin only ─────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
